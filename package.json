{
  "name": "ryxen",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:hub:tailwind && npm run build:athlete:tailwind && node scripts/build-static.mjs && vite build --config coach-portal/vite.config.mjs && node scripts/generate-marketing-assets.mjs",
    "build:prod": "npm run build:hub:tailwind && npm run build:athlete:tailwind && node scripts/build-static.mjs && vite build --config coach-portal/vite.config.mjs && node scripts/generate-marketing-assets.mjs",
    "build:coach": "vite build --config coach-portal/vite.config.mjs",
    "build:hub:tailwind": "tailwindcss -i ./src/hub/tailwind.css -o ./src/hub/tailwind.generated.css --minify",
    "build:athlete:tailwind": "tailwindcss -i ./src/ui/tailwind.css -o ./src/ui/tailwind.generated.css --minify",
    "generate:marketing-assets": "node scripts/generate-marketing-assets.mjs",
    "lint": "eslint .",
    "check": "npm run lint && npm test && npm run build",
    "build:android": "npm run build",
    "dev:backend-supabase": "bash scripts/dev-backend-supabase.sh",
    "smoke:backend-supabase": "bash scripts/smoke-backend-supabase.sh",
    "dev:backend-supabase-and-smoke": "bash scripts/dev-backend-supabase-and-smoke.sh",
    "android:sync": "npm run build:android && npx cap sync android",
    "android:copy": "npm run build:android && npx cap copy android",
    "android:open": "CAPACITOR_ANDROID_STUDIO_PATH=$PWD/scripts/open-android-studio.sh npx cap open android",
    "android:run": "npm run build:android && npx cap run android",
    "generate:import-fixtures": "node scripts/generate-import-fixtures.mjs",
    "report:import-support": "node scripts/report-import-format-support.mjs",
    "test": "node --test __tests__/*.test.mjs",
    "test:e2e": "playwright test --project=chromium",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "seed:coach-trial": "node scripts/seed-coach-trial.mjs",
    "smoke:coach-trial": "node scripts/smoke-coach-trial.mjs",
    "validate:stack": "bash scripts/validate-stack.sh",
    "seed:admin-playground": "node backend/scripts/seed-admin-playground.mjs",
    "docker:up": "bash scripts/docker-up.sh",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=200",
    "docker:ps": "docker compose ps",
    "deploy:prod": "vercel --prod"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@lokalise/xlsx": "^0.20.3",
    "@sentry/browser": "^10.47.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.7"
  },
  "overrides": {
    "tar": "^7.5.13"
  }
}
