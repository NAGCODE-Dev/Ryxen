{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "ignoreCommand": "node scripts/vercel-ignore-build.mjs",
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://crossapp-znmj.onrender.com/$1" },
    { "source": "/auth/callback", "destination": "/auth/callback/index.html" },
    { "source": "/athlete", "destination": "/athlete/index.html" },
    { "source": "/athlete/", "destination": "/athlete/index.html" },
    { "source": "/sports/cross", "destination": "/sports/cross/index.html" },
    { "source": "/sports/cross/", "destination": "/sports/cross/index.html" },
    { "source": "/sports/running", "destination": "/sports/running/index.html" },
    { "source": "/sports/running/", "destination": "/sports/running/index.html" },
    { "source": "/sports/strength", "destination": "/sports/strength/index.html" },
    { "source": "/sports/strength/", "destination": "/sports/strength/index.html" },
    { "source": "/coach", "destination": "/coach/index.html" },
    { "source": "/coach/", "destination": "/coach/index.html" }
  ]
}
