{
  "outputDirectory": "dist",
  "ignoreCommand": "node scripts/vercel-ignore-build.mjs",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://crossapp-znmj.onrender.com/api/$1" },
    { "source": "/sports/cross", "destination": "/sports/cross/index.html" },
    { "source": "/sports/cross/", "destination": "/sports/cross/index.html" },
    { "source": "/sports/running", "destination": "/sports/running/index.html" },
    { "source": "/sports/running/", "destination": "/sports/running/index.html" },
    { "source": "/sports/strength", "destination": "/sports/strength/index.html" },
    { "source": "/sports/strength/", "destination": "/sports/strength/index.html" },
    { "source": "/coach", "destination": "/coach/index.html" },
    { "source": "/coach/", "destination": "/coach/index.html" }
  ]
}
